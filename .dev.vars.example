# Copy this file to `.dev.vars` for `wrangler dev`.
# Do not commit `.dev.vars`; it contains local Worker secrets.

# Required for encrypting admin-saved secrets and signing sessions.
# Use a stable 32+ byte random value; rotating it invalidates sessions and encrypted configs.
NOTIFY_SECRET_KEY=replace-with-32-byte-random-secret

# Optional: required only when enabling /api/webhooks/:provider endpoints.
WEBHOOK_SECRET=replace-with-provider-webhook-secret

# Optional and normally disabled: exposes temporary migration/debug admin endpoints.
# Keep this unset or false in production unless you are actively running a migration check.
ENABLE_TEMP_ADMIN_ENDPOINTS=false

# Optional and normally disabled: temporarily allows legacy full-state PUT writes.
# Keep false; segmented domain APIs are the supported write path.
ENABLE_LEGACY_STATE_WRITE=false

# Optional and experimental: enables incomplete normalized-table reads in local D1 only.
# Keep false unless actively testing hybrid-read coverage.
USE_NORMALIZED_TABLES=false
ALLOW_UNSTABLE_NORMALIZED_READS=false
