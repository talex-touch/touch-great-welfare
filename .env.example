# 本地工具变量，不会被 Worker 运行时直接读取。
# 仅用于创建 Hyperdrive；本地开发默认使用 Cloudflare D1 local store。
DATABASE_URL=postgresql://user:password@host:5432/touch_great_welfare
# 仅用于 CI / 无浏览器部署；本地 OAuth 登录 Wrangler 时不需要。
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudflare Bindings 由 wrangler.jsonc / wrangler.production.jsonc 配置，不写入 .env：
# - LOCAL_DB：本地 D1 数据库 binding。
# - HYPERDRIVE：生产 PostgreSQL Hyperdrive binding。
# - AI_ASSETS：AI 图片结果 R2 bucket binding。

# 必需 Worker Secret：用于加密后台保存的密钥类配置。
NOTIFY_SECRET_KEY=replace-with-32-byte-random-secret

# Legacy fallback：以下业务配置已支持在管理员后台保存，仅用于兼容旧部署。
LDC_PAYMENT_ENABLED=true
LDC_GATEWAY_BASE_URL=https://credit.linux.do/epay
LDC_PID=your-ldc-client-id
LDC_KEY=your-ldc-client-secret

GITHUB_APP_ENABLED=false
GITHUB_APP_NAME="Touch Great Welfare"
GITHUB_APP_SLUG=touch-great-welfare
GITHUB_APP_CLIENT_ID=your-github-app-client-id
GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
GITHUB_APP_CALLBACK_URL=http://localhost:8787/api/github-app/callback
GITHUB_APP_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_APP_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_APP_API_BASE_URL=https://api.github.com
GITHUB_APP_SCOPES="read:user user:email public_repo"

AI_PROVIDER_ENABLED=false
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_IMAGE_MODEL=gpt-image-1.5
AI_REVIEW_MODEL=gpt-4.1-mini
NEWAPI_MANAGEMENT_BASE_URL=https://apifox.newapi.ai/384083922e0
NEWAPI_USER_ID=
NEWAPI_TEMP_KEY_TTL_MINUTES=60
NEWAPI_TEMP_KEY_QUOTA=100
OPENAI_API_KEY=sk-your-openai-key
NEWAPI_API_KEY=sk-your-newapi-admin-key

RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL="Touch Great Welfare <notice@example.com>"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com
