# 本地工具变量，不会被 Worker 运行时直接读取。
# 仅用于创建 Hyperdrive；本地开发默认使用 Cloudflare D1 local store。
DATABASE_URL=postgresql://user:password@host:5432/touch_great_welfare
# 仅用于 CI / 无浏览器部署；本地 OAuth 登录 Wrangler 时不需要。
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudflare Bindings 由 wrangler.jsonc / wrangler.production.jsonc 配置，不写入 .env：
# - LOCAL_DB：本地 D1 数据库 binding。
# - HYPERDRIVE：生产 PostgreSQL Hyperdrive binding。
# - AI_ASSETS：AI 图片结果 R2 bucket binding。

# 必需 Worker Secret：用于加密后台保存的密钥类配置，并签发登录 Session。
# 生产环境必须稳定保存；更换会导致已保存的加密配置不可解密、现有 Session 失效。
NOTIFY_SECRET_KEY=replace-with-32-byte-random-secret

# 可选 Worker Secret：启用 /api/webhooks/:provider 时用于 HMAC-SHA256 验签。
# 也可按 provider 设置 WEBHOOK_SECRET_<PROVIDER>，例如 WEBHOOK_SECRET_GITHUB。
WEBHOOK_SECRET=replace-with-provider-webhook-secret

# 可选 Worker 变量：临时迁移/调试管理端点开关。
# 默认保持 false；只有执行迁移检查时才临时设为 true。
ENABLE_TEMP_ADMIN_ENDPOINTS=false

# 可选 Worker 变量：临时放行旧版 /api/welfare-state 全量保存。
# 默认保持 false；生产配置检查禁止开启，只能用于迁移应急。
ENABLE_LEGACY_STATE_WRITE=false

# 可选 Worker 变量：试验性规范化快照读取双开关，必须同时开启。
# 当前仅应用和优惠券使用快照覆盖，其余字段回退完整状态；生产配置检查禁止开启。
USE_NORMALIZED_TABLES=false
ALLOW_UNSTABLE_NORMALIZED_READS=false
